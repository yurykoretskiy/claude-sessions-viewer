{
  "name": "claude-sessions-viewer",
  "displayName": "Claude Sessions Viewer",
  "description": "Read Claude Code sessions like chat: locate current work, review history, export Markdown. Read-only, local, zero dependencies.",
  "version": "1.11.0",
  "publisher": "yurykoretskiy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./extension.js",
  "scripts": {
    "test": "node --test"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Browsing and reading sessions works in untrusted workspaces. Starting or resuming a session opens a visible terminal, so those actions are best used in trusted workspaces."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Reads Claude Code session files from the local disk (~/.claude), which is unavailable in virtual workspaces."
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSessions",
          "title": "Claude Sessions",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "claudeSessions": [
        {
          "id": "claudeSessions.tree",
          "name": "Sessions by Folder"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.revealCurrent",
        "title": "Claude Sessions: Reveal current session",
        "icon": {
          "light": "assets/reveal-spark.svg",
          "dark": "assets/reveal-spark.svg"
        }
      },
      {
        "command": "claudeSessions.newHere",
        "title": "Claude: New session here",
        "icon": "$(add)"
      },
      {
        "command": "claudeSessions.newWindowHere",
        "title": "Claude: New window session here (panel)",
        "icon": "$(empty-window)"
      },
      {
        "command": "claudeSessions.toggleGrouping",
        "title": "Claude Sessions: Switch to session timeline (now: folders A-Z)",
        "icon": "$(list-tree)"
      },
      {
        "command": "claudeSessions.toggleGroupingAlt",
        "title": "Claude Sessions: Switch to folders A-Z (now: session timeline)",
        "icon": "$(list-flat)"
      },
      {
        "command": "claudeSessions.showInFolders",
        "title": "Claude: Show in folder view"
      },
      {
        "command": "claudeSessions.resume",
        "title": "Claude: Resume session",
        "icon": "$(play)"
      },
      {
        "command": "claudeSessions.rename",
        "title": "Claude: Rename session"
      },
      {
        "command": "claudeSessions.openConversation",
        "title": "Claude: Open as conversation (read-only)",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeSessions.refresh",
        "title": "Claude Sessions: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.expandAll",
        "title": "Claude Sessions: Expand folders",
        "icon": "$(expand-all)"
      },
      {
        "command": "claudeSessions.collapseAll",
        "title": "Claude Sessions: Collapse folders",
        "icon": "$(collapse-all)"
      },
      {
        "command": "claudeSessions.openTranscript",
        "title": "Claude: Open transcript (.jsonl)"
      },
      {
        "command": "claudeSessions.copySessionId",
        "title": "Claude: Copy session id"
      },
      {
        "command": "claudeSessions.openSettings",
        "title": "Claude Sessions: Open Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "claudeSessions.newHere",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@98"
        },
        {
          "command": "claudeSessions.newWindowHere",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@99"
        }
      ],
      "view/title": [
        {
          "command": "claudeSessions.toggleGrouping",
          "when": "view == claudeSessions.tree && claudeSessions.mode == 'folders' && claudeSessions.timelineEnabled",
          "group": "navigation@0"
        },
        {
          "command": "claudeSessions.toggleGroupingAlt",
          "when": "view == claudeSessions.tree && claudeSessions.mode == 'chronological' && claudeSessions.timelineEnabled",
          "group": "navigation@0"
        },
        {
          "command": "claudeSessions.expandAll",
          "when": "view == claudeSessions.tree && !claudeSessions.expandedAll && claudeSessions.mode == 'folders'",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.collapseAll",
          "when": "view == claudeSessions.tree && claudeSessions.expandedAll && claudeSessions.mode == 'folders'",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.refresh",
          "when": "view == claudeSessions.tree",
          "group": "navigation@2"
        },
        {
          "command": "claudeSessions.openSettings",
          "when": "view == claudeSessions.tree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSessions.newHere",
          "when": "view == claudeSessions.tree && viewItem == folder",
          "group": "inline"
        },
        {
          "command": "claudeSessions.newWindowHere",
          "when": "view == claudeSessions.tree && viewItem == folder"
        },
        {
          "command": "claudeSessions.openConversation",
          "when": "view == claudeSessions.tree && viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "claudeSessions.showInFolders",
          "when": "view == claudeSessions.tree && viewItem == session && claudeSessions.mode == 'chronological'",
          "group": "1_actions@1"
        },
        {
          "command": "claudeSessions.rename",
          "when": "view == claudeSessions.tree && viewItem == session",
          "group": "1_actions@2"
        },
        {
          "command": "claudeSessions.openTranscript",
          "when": "view == claudeSessions.tree && viewItem == session"
        },
        {
          "command": "claudeSessions.copySessionId",
          "when": "view == claudeSessions.tree && viewItem == session"
        }
      ],
      "editor/title": [
        {
          "command": "claudeSessions.revealCurrent",
          "when": "activeWebviewPanelId == 'claudeVSCodePanel' && config.claudeSessionsViewer.reveal.enabled",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": [
      {
        "title": "Claude Sessions Viewer",
        "order": 1,
        "properties": {
          "claudeSessionsViewer.reveal.enabled": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "scope": "window",
            "markdownDescription": "Show the **Reveal current session** ✳ button on the Claude Code panel tab and in the status bar."
          },
          "claudeSessionsViewer.reveal.openConversation": {
            "type": "boolean",
            "default": true,
            "order": 2,
            "scope": "window",
            "markdownDescription": "When you reveal the current session, also open its **read-only conversation** beside the editor.\n\n- On (default): great for exploring — reveal shows the chat.\n- Off: reveal only highlights the session in the tree."
          }
        }
      },
      {
        "title": "Conversation Viewer",
        "order": 2,
        "properties": {
          "claudeSessionsViewer.theme": {
            "type": "string",
            "enum": [
              "system",
              "light",
              "dark"
            ],
            "enumDescriptions": [
              "Follow the current VS Code theme",
              "Always light",
              "Always dark"
            ],
            "default": "system",
            "order": 1,
            "scope": "window",
            "markdownDescription": "Theme for the conversation viewer."
          },
          "claudeSessionsViewer.userLabel": {
            "type": "string",
            "default": "USER",
            "order": 2,
            "scope": "window",
            "markdownDescription": "Label shown on **your** messages in the viewer and in copies/exports. Kept generic so shared conversations never expose a personal name."
          },
          "claudeSessionsViewer.agentLabel": {
            "type": "string",
            "default": "CLAUDE",
            "order": 3,
            "scope": "window",
            "markdownDescription": "Label shown on assistant messages in the viewer and in copies/exports."
          },
          "claudeSessionsViewer.showNames": {
            "type": "boolean",
            "default": true,
            "order": 4,
            "scope": "window",
            "markdownDescription": "Show speaker names inside conversation bubbles. On by default so sessions stay clear when shared or when future agents are involved."
          },
          "claudeSessionsViewer.liveRefresh.enabled": {
            "type": "boolean",
            "default": false,
            "order": 5,
            "scope": "window",
            "markdownDescription": "Keep an open conversation updating **live** while its session keeps writing. Off by default to stay light."
          }
        }
      },
      {
        "title": "Sessions Tree",
        "order": 3,
        "properties": {
          "claudeSessionsViewer.promptChildren.enabled": {
            "type": "boolean",
            "default": false,
            "order": 1,
            "scope": "window",
            "markdownDescription": "Show your prompt/message preview rows **under each session** in the tree. Off by default for faster, session-level browsing."
          },
          "claudeSessionsViewer.showAutomationSessions": {
            "type": "boolean",
            "default": false,
            "order": 2,
            "scope": "window",
            "markdownDescription": "Also show **automation sessions** — transcripts created by SDK runs such as `/security-review` and background agents, not conversations you had. Off by default: the tree then matches the sessions the official Claude Code panel shows."
          },
          "claudeSessionsViewer.timeline.enabled": {
            "type": "boolean",
            "default": false,
            "order": 3,
            "scope": "window",
            "markdownDescription": "Show the experimental **Session Timeline** toggle. Off by default while the flat view is being redesigned for a clearer two-column layout."
          }
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yurykoretskiy/claude-sessions-viewer.git"
  },
  "homepage": "https://github.com/yurykoretskiy/claude-sessions-viewer#readme",
  "icon": "assets/icon.png",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "session",
    "history",
    "conversation",
    "transcript",
    "viewer",
    "ai",
    "productivity"
  ],
  "galleryBanner": {
    "color": "#1a1a1b",
    "theme": "dark"
  }
}
