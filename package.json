{
  "name": "claude-sessions-viewer",
  "displayName": "Claude Sessions Viewer",
  "description": "Browse Claude Code sessions grouped by project folder; right-click any folder to start a Claude session there.",
  "version": "1.4.5",
  "publisher": "yury",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSessions",
          "title": "Claude Sessions",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "claudeSessions": [
        {
          "id": "claudeSessions.tree",
          "name": "Sessions by Folder"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.revealCurrent",
        "title": "Claude Sessions: Reveal current session",
        "icon": "$(sparkle)"
      },
      {
        "command": "claudeSessions.newHere",
        "title": "Claude: New session here",
        "icon": "$(add)"
      },
      {
        "command": "claudeSessions.newWindowHere",
        "title": "Claude: New window session here (panel)",
        "icon": "$(empty-window)"
      },
      {
        "command": "claudeSessions.toggleGrouping",
        "title": "Claude Sessions: Grouping by working folders — click for Claude raw storage",
        "icon": "$(list-tree)"
      },
      {
        "command": "claudeSessions.toggleGroupingAlt",
        "title": "Claude Sessions: Grouping by Claude raw storage — click for working folders",
        "icon": "$(list-flat)"
      },
      {
        "command": "claudeSessions.resume",
        "title": "Claude: Resume session",
        "icon": "$(play)"
      },
      {
        "command": "claudeSessions.search",
        "title": "Claude Sessions: Search sessions",
        "icon": "$(search)"
      },
      {
        "command": "claudeSessions.rename",
        "title": "Claude: Rename session"
      },
      {
        "command": "claudeSessions.openConversation",
        "title": "Claude: Open as conversation (read-only)",
        "icon": "$(open-preview)"
      },
      {
        "command": "claudeSessions.refresh",
        "title": "Claude Sessions: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.openTranscript",
        "title": "Claude: Open transcript (.jsonl)"
      },
      {
        "command": "claudeSessions.copySessionId",
        "title": "Claude: Copy session id"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "claudeSessions.newHere",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@98"
        },
        {
          "command": "claudeSessions.newWindowHere",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@99"
        }
      ],
      "view/title": [
        {
          "command": "claudeSessions.search",
          "when": "view == claudeSessions.tree",
          "group": "navigation@0"
        },
        {
          "command": "claudeSessions.toggleGrouping",
          "when": "view == claudeSessions.tree && claudeSessions.mode == 'smart'",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.toggleGroupingAlt",
          "when": "view == claudeSessions.tree && claudeSessions.mode == 'raw'",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.refresh",
          "when": "view == claudeSessions.tree",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSessions.newHere",
          "when": "view == claudeSessions.tree && viewItem == folder",
          "group": "inline"
        },
        {
          "command": "claudeSessions.newWindowHere",
          "when": "view == claudeSessions.tree && viewItem == folder"
        },
        {
          "command": "claudeSessions.openConversation",
          "when": "view == claudeSessions.tree && viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "claudeSessions.rename",
          "when": "view == claudeSessions.tree && viewItem == session",
          "group": "1_actions@2"
        },
        {
          "command": "claudeSessions.openTranscript",
          "when": "view == claudeSessions.tree && viewItem == session"
        },
        {
          "command": "claudeSessions.copySessionId",
          "when": "view == claudeSessions.tree && viewItem == session"
        }
      ],
      "editor/title": [
        {
          "command": "claudeSessions.revealCurrent",
          "when": "activeWebviewPanelId == 'claudeVSCodePanel' && config.claudeSessionsViewer.reveal.enabled",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Claude Sessions Viewer",
      "properties": {
        "claudeSessionsViewer.theme": {
          "type": "string",
          "enum": [
            "system",
            "light",
            "dark"
          ],
          "default": "system",
          "description": "Conversation viewer theme. System follows the VS Code theme."
        },
        "claudeSessionsViewer.userLabel": {
          "type": "string",
          "default": "USER",
          "description": "Label shown on your messages in the conversation viewer and in copies/exports."
        },
        "claudeSessionsViewer.reveal.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show and enable Reveal current session controls."
        },
        "claudeSessionsViewer.reveal.openConversation": {
          "type": "boolean",
          "default": true,
          "description": "When revealing the current session, also open the read-only conversation viewer beside the active editor. New users see the review pane by default; switch this off for tree-only reveal."
        },
        "claudeSessionsViewer.liveRefresh.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Refresh an open conversation viewer while its transcript changes. Off by default to keep active sessions lighter."
        },
        "claudeSessionsViewer.promptChildren.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show user prompt/message preview rows under each session in the tree. Off by default for session-level browsing."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yurykoretskiy/claude-sessions-viewer.git"
  },
  "homepage": "https://github.com/yurykoretskiy/claude-sessions-viewer#readme"
}
